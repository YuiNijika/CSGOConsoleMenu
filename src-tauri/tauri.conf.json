{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-app",
  "version": "0.1.0",
  "identifier": "com.yuinijika.csgo.consolemenu",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CSGO Console Menu",
        "width": 450,
        "height": 650,
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "visible": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/csgo.png"
    ]
  }
}
